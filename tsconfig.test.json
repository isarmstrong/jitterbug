{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": [
      "vitest/globals",
      "node"
    ],
    "outDir": "dist-test"
  },
  "include": [
    "src/**/*",
    "__tests__/**/*",
    "test/**/*",
    "vitest.config.ts",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-test"
  ]
}