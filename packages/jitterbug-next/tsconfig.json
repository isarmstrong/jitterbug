{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "declaration": true,
        "outDir": "dist",
        "rootDir": "src",
        "baseUrl": ".",
        "paths": {
            "@core/types": [
                "../../src/types/core.ts"
            ],
            "@core/enums": [
                "../../src/types/enums.ts"
            ],
            "@core/edge": [
                "../../src/types/edge.ts"
            ],
            "@transports/base": [
                "../../src/transports/base.ts"
            ],
            "@transports/*": [
                "../../src/transports/*.ts"
            ],
            "@processors/*": [
                "../../src/processors/*.ts"
            ],
            "@utils/*": [
                "../../src/utils/*.ts"
            ]
        },
        "jsx": "preserve",
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        "src/**/*.ts",
        "src/**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}