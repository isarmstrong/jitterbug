{
    "name": "@isarmstrong/jitterbug-next",
    "version": "1.0.0-rc.1",
    "description": "Next.js integration for Jitterbug logger",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "styles.css"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.json && cp src/styles.css dist/styles.css",
        "prepack": "npm run build",
        "test": "vitest",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.0"
    },
    "peerDependencies": {
        "@isarmstrong/jitterbug": "^1.0.0-rc.1",
        "next": ">=13.0.0",
        "react": ">=18.0.0",
        "@headlessui/react": "^2.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "eslint": "^8.56.0",
        "next": "^15.1.6",
        "typescript": "^5.0.0",
        "vitest": "^1.0.0"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./debug": {
            "types": "./dist/components/debug/index.d.ts",
            "import": "./dist/components/debug/index.js",
            "require": "./dist/components/debug/index.js",
            "default": "./dist/components/debug/index.js"
        },
        "./api": {
            "types": "./dist/api/index.d.ts",
            "import": "./dist/api/index.js",
            "require": "./dist/api/index.js",
            "default": "./dist/api/index.js"
        },
        "./styles.css": "./dist/styles.css"
    }
}